\@writefile{lot}{\contentsline {table}{\numberline {V}{\ignorespaces \textbf  {Full-site knockout causal gradient.} Zeroing all channels at each UNet site and re-evaluating H1. The causal importance follows a monotonic depth gradient: deepest downsampling representations are indispensable, while early upsampling representations are largely dispensable. The pattern is identical across both checkpoints.}}{7}{table.5}\protected@file@percent }
\newlabel{tab:full-site-ko}{{V}{7}{\textbf {Full-site knockout causal gradient.} Zeroing all channels at each UNet site and re-evaluating H1. The causal importance follows a monotonic depth gradient: deepest downsampling representations are indispensable, while early upsampling representations are largely dispensable. The pattern is identical across both checkpoints}{table.5}{}}
