\@writefile{lot}{\contentsline {table}{\numberline {VI}{\ignorespaces \textbf  {Spatial--temporal causal grid.} $\Delta $AUC when zeroing all channels at each site$\times $timestep. Early denoising ($t{=}100$) at the bottleneck (mid\_0) and deepest layers (late\_down) carries essentially all membership signal. The pattern is identical across DDPM 800k and DDIM 750k.}}{7}{table.6}\protected@file@percent }
\newlabel{tab:spatiotemporal-ko}{{VI}{7}{\textbf {Spatial--temporal causal grid.} $\Delta $AUC when zeroing all channels at each site$\times $timestep. Early denoising ($t{=}100$) at the bottleneck (mid\_0) and deepest layers (late\_down) carries essentially all membership signal. The pattern is identical across DDPM 800k and DDIM 750k}{table.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {VII}{\ignorespaces \textbf  {Fine temporal grid knockout (8 timesteps).} DDPM training produces temporally distributed signal: 0 of 16 individual knockouts exceed $\Delta {=}0.05$. DDIM training produces temporally concentrated signal: all 16 knockouts exceed $\Delta {=}0.09$, with late\_down@$t{=}100$ destroying 26\% of AUC.}}{7}{table.7}\protected@file@percent }
\newlabel{tab:fine-temporal}{{VII}{7}{\textbf {Fine temporal grid knockout (8 timesteps).} DDPM training produces temporally distributed signal: 0 of 16 individual knockouts exceed $\Delta {=}0.05$. DDIM training produces temporally concentrated signal: all 16 knockouts exceed $\Delta {=}0.09$, with late\_down@$t{=}100$ destroying 26\% of AUC}{table.7}{}}
\@writefile{lot}{\contentsline {table}{\numberline {VIII}{\ignorespaces \textbf  {Three-way temporal distribution comparison (8 timesteps).} Temporal signal concentration differs across both training procedures and datasets. CIFAR-10 DDPM yields distributed signal; DDIM training and CIFAR-100 produce concentrated signal. The mechanism is underdetermined with two datasets (N=2)---class count, samples-per-class, and training-procedure interactions are candidates for future investigation.}}{8}{table.8}\protected@file@percent }
\newlabel{tab:three-way-temporal}{{VIII}{8}{\textbf {Three-way temporal distribution comparison (8 timesteps).} Temporal signal concentration differs across both training procedures and datasets. CIFAR-10 DDPM yields distributed signal; DDIM training and CIFAR-100 produce concentrated signal. The mechanism is underdetermined with two datasets (N=2)---class count, samples-per-class, and training-procedure interactions are candidates for future investigation}{table.8}{}}
