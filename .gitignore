# =============================================================================
# .gitignore — DiffAudit Research
# =============================================================================

# ---------------------------------------------------------------------------
# 1. Python
# ---------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
*.egg-info/
dist/

# ---------------------------------------------------------------------------
# 2. Datasets (large binary data files)
# ---------------------------------------------------------------------------
data/datasets/
!data/splits/*.npz
*.npz
*.npy
*.tar.gz
*.tgz
*.tar
*.zip
*.7z
*.rar
*.bin

# ---------------------------------------------------------------------------
# 3. Model weights (large checkpoints)
# ---------------------------------------------------------------------------
*.pt
*.pth
*.ckpt
*.safetensors
Download/

# ---------------------------------------------------------------------------
# 4. Outputs (all generated results, caches, logs)
# ---------------------------------------------------------------------------
outputs/
/tmp/
*.stdout.log
*.stderr.log

# ---------------------------------------------------------------------------
# 5. PDFs (papers — keep figures/ directories)
# ---------------------------------------------------------------------------
papers/*.pdf
papers/**/*.pdf
*.pdf
!figures/
!**/figures/
!**/figures/**

# ---------------------------------------------------------------------------
# 5b. Images (keep curated figures/docs/brand)
# ---------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.webp
!references/materials/tracing-roots-arxiv-v3-20260515/figures/*.png
!references/materials/tracing-roots-arxiv-v3-20260515/figures/*.pdf
!docs/brand/*.svg
!workspaces/white-box/smoke-ddpm/train/member/sample.ppm

# ---------------------------------------------------------------------------
# 6. Workspaces (stale runs — curated artifacts excepted below)
# ---------------------------------------------------------------------------
workspaces/

